{
  "name": "media-app",
  "version": "0.1.147",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "bash scripts/start-prod.sh",
    "update": "bash scripts/update.sh",
    "release": "bash scripts/release.sh",
    "db:generate": "pnpm --filter @media-app/server db:generate",
    "db:migrate": "pnpm --filter @media-app/server db:migrate",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:watch": "turbo test -- --watch",
    "android:build": "cd packages/android-tv && ./gradlew assembleDebug",
    "android:build:release": "cd packages/android-tv && ./gradlew assembleRelease",
    "tv-deploy": "bash scripts/deploy-android-tv.sh",
    "tv-deploy:release": "bash scripts/deploy-android-tv.sh --release"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
